0,"elapsed":2044,"user":{"displayName":"Gobisan Ananthanadarajan","userId":"08370486503672403873"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["X_train = df.loc[:25000, 'review'].values\n","y_train = df.loc[:25000, 'sentiment'].values\n","X_test  = df.loc[25000:, 'review'].values\n","y_test  = df.loc[25000:, 'sentiment'].values"],"outputs":[],"execution_count":7,"metadata":{"id":"--8a-ZIy6AQY","executionInfo":{"status":"ok","timestamp":1781185493617,"user_tz":-330,"elapsed":5,"user":{"displayName":"Gobisan Ananthanadarajan","userId":"08370486503672403873"}}}},{"cell_type":"markdown","source":["---\n","\n","### **2. Pipeline Setup and Grid Search**\n","\n","A `GridSearchCV` object is used to find the optimal parameters for a logistic regression model using 5-fold stratified cross-validation.\n","\n","**Key Configuration Notes:**\n","\n","* **Vectorizer:** Replaces `CountVectorizer` and `TfidfTransformer` with `TfidfVectorizer`, which combines both.\n","* **Solver:** The `LIBLINEAR` solver is explicitly chosen for the `LogisticRegression` classifier because it typically outperforms the default `lbfgs` solver on relatively large datasets.\n","* **Parameter Grid:**\n","  * *Grid 1:* Uses default settings (`use_idf=True`, `smooth_idf=True`, `norm='l2'`) to calculate tf-idfs.\n","  * *Grid 2:* Calculates based on raw term frequencies (`use_idf=False`, `smooth_idf=False`, `norm=None`).\n","  * Both test the inverse-regularization parameter (`C`) at `1.0` and `10.0` using L2 regularization (`penalty='l2'`).\n","\n","\n","* **Performance:** Grid searching over a large vocabulary is computationally expensive. Setting `n_jobs=-1` utilizes all machine cores."],"metadata":{"id":"OS-BUPK76AQZ"}},{"cell_type":"code","source":["from sklearn.model_selection import GridSearchCV\n","from sklearn.pipeline import Pipeline\n","from sklearn.linear_model import LogisticRegression\n","from sklearn.feature_extraction.text import TfidfVectorizer\n","\n","# Import necessary NLTK components for tokenization\n","import nltk\n","import re\n","from nltk.corpus import stopwords\n","from nltk.stem.porter import PorterStemmer\n","\n","nltk.download('stopwords')\n","\n","# Define tokenizers and stop words\n","stop = stopwords.words('english')\n","poter = PorterStemmer()\n","\n","def tokenizer(text):\n","    text = re.sub(r'<[^>]*>', '', text)\n","    emoticons = re.findall(r'(?::|;|=)(?:-)?(?:\\)|D|P)', text)\n","    text = (re.sub(r'[\\W]+', ' ', text.lower()) +\n","            ' '.join(emoticons).replace('-', ''))\n","    tokenized = [w for w in text.split() if w not in stop]\n","    return tokenized\n","\n","def tokenizer_porter(text):\n","    text = re.sub(r'<[^>]*>', '', text)\n","    emoticons = re.findall(r'(?::|;|=)(?:-)?(?:\\)|D|P)', text)\n","    text = (re.sub(r'[\\W]+', ' ', text.lower()) +\n","            ' '.join(emoticons).replace('-', ''))\n","    tokenized = [poter.stem(w) for w in text.split() if w not in stop]\n","    return tokenized\n","\n","\n","# Initialize TfidfVectorizer\n","tfidf = TfidfVectorizer(strip_accents=None,\n","                        lowercase=False,\n","                        preprocessor=None)\n","\n","# Define the parameter grid\n","small_param_grid = [\n","    {\n","        'vect__ngram_range': [(1, 1)],\n","        'vect__stop_words': [None],\n","        'vect__tokenizer': [tokenizer, tokenizer_porter],\n","        'clf__penalty': ['l2'],\n","        'clf__C': [1.0, 10.0]\n","    },\n","    {\n","        'vect__ngram_range': [(1, 1)],\n","        'vect__stop_words': [stop, None],\n","        'vect__tokenizer': [tokenizer],\n","        'vect__use_idf': [False],\n","        'vect__norm': [None],\n","        'clf__penalty': ['l2'],\n","        'clf__C': [1.0, 10.0]\n","    }\n","]\n","\n","# Create Pipeline\n","lr_tfidf = Pipeline([\n","    ('vect', tfidf),\n","    ('clf', LogisticRegression(solver='liblinear'))\n","])\n","\n","# Initialize GridSearchCV\n","gs_lr_tfidf = GridSearchCV(lr_tfidf, small_param_grid,\n","                           scoring='accuracy', cv=5,\n","                           verbose=2, n_jobs=1)\n","\n","# Fit the model (may take 5-10 minutes on standard hardware)\n","gs_lr_tfidf.fit(X_train, y_train)"],"outputs":[{"output_type":"stream","name":"stderr","text":["<>:20: SyntaxWarning: invalid escape sequence '\\)'\n","<>:21: SyntaxWarning: invalid escape sequence '\\W'\n","<>:28: SyntaxWarning: invalid escape sequence '\\)'\n","<>:29: SyntaxWarning: invalid escape sequence '\\W'\n","<>:20: SyntaxWarning: invalid escape sequence '\\)'\n","<>:21: SyntaxWarning: invalid escape sequence '\\W'\n","<>:28: SyntaxWarning: invalid escape sequence '\\)'\n","<>:29: SyntaxWarning: invalid escape sequence '\\W'\n","/tmp/ipykernel_4954/2513611332.py:20: SyntaxWarning: invalid escape sequence '\\)'\n","  emoticons = re.findall('(?::|;|=)(?:-)?(?:\\)|D|P)', text)\n","/tmp/ipykernel_4954/2513611332.py:21: SyntaxWarning: invalid escape sequence '\\W'\n","  text = (re.sub('[\\W]+', ' ', text.lower()) +\n","/tmp/ipykernel_4954/2513611332.py:28: SyntaxWarning: invalid escape sequence '\\)'\n","  emoticons = re.findall('(?::|;|=)(?:-)?(?:\\)|D|P)', text)\n","/tmp/ipykernel_4954/2513611332.py:29: SyntaxWarning: invalid escape sequence '\\W'\n","  text = (re.sub('[\\W]+', ' ', text.lower()) +\n","[nltk_data] Downloading package stopwords to /root/nltk_data...\n","[nltk_data]   Unzipping corpora/stopwords.zip.\n","/usr/local/lib/python3.12/dist-packages/sklearn/feature_extraction/text.py:517: UserWarning: The parameter 'token_pattern' will not be used since 'tokenizer' is not None'\n","  warnings.warn(\n"]},{"output_type":"stream","name":"stdout","text":["Fitting 5 folds for each of 8 candidates, totalling 40 fits\n","[CV] END clf__C=1.0, clf__penalty=l2, vect__ngram_range=(1, 1), vect__stop_words=None, vect__tokenizer=<function tokenizer at 0x7e7b1126fc40>; total time=  12.3s\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-pack