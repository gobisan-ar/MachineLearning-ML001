
  # Byte-compiled / optimized / DLL files
  __pycache__/
  *.py[cod]
  *$py.class

  # Colab / Jupyter Notebook specifics
  .ipynb_checkpoints/
  .virtual_documents/

  # Machine Learning - Model Weights (Heavy files)
  *.pth
  *.h5
  *.weights
  *.pkl
  *.joblib
  *.onnx

  # Data (Avoid uploading massive datasets to GitHub)
  data/
  datasets/
  *.csv
  *.tsv
  *.zip
  *.tar.gz

  # Environment & OS
  .env
  .DS_Store
  